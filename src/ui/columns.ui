  <property name="styleSheet">
   <string notr="true">/* =========================
   Global settings
   ========================= */
#form {
    background-color: #00181a;
	font-family: Segoe UI;
}

/* Selection colors */
QLineEdit {
	selection-background-color: #7dd3c0;
	selection-color: #ffffff;
}

/* =========================
   Frames
   ========================= */
QFrame {
    border-radius: 6px;
}

#titleFrame {
    background-color: #00585a;
    padding: 15px;
	margin: 20px 20px 10px 20px;
}

#contentFrame {
    background-color: #89b3af;
    padding: 15px;
	margin: 0px 20px 10px 20px;
}

#buttonsFrame {
    background-color: transparent;
	margin: 10px 20px 20px 20px;
}

/* =========================
   Title styling
   ========================= */
#titleLabel {
    font-size: 18pt;
    font-weight: 600;
    color: #F2F1ED;
}

#instructionLabel {
    font-size: 12pt;
    font-weight: 400;
    color: #89b3af;
}

/* =========================
   Scroll area
   ========================= */
QScrollArea {
    border: none;
    background-color: transparent;
}

QScrollBar:vertical {
    border: none;
    background: #4C5A5D;
    width: 10px;
    border-radius: 5px;
}

QScrollBar::handle:vertical {
    background: #6B7B7E;
    border-radius: 5px;
}

QScrollBar::handle:vertical:hover {
    background: #7B8B8E;
}

/* =========================
   Item cards
   ========================= */
#criteriaWidget {
    background-color: transparent;
}

/* =========================
   Buttons
   ========================= */
#backBtn {
    background-color: #00989b;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 12px 24px;
    font-size: 14pt;
    font-weight: 600;
    min-width: 120px;
}

#backBtn:hover {
    background-color: #00bcc0;
}

#backBtn:pressed {
    background-color: #01797b;
}

#addBtn {
    background-color: #2fb14d;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    font-size: 24pt;
    font-weight: bold;
    min-width: 50px;
    min-height: 50px;
    max-width: 50px;
    max-height: 50px;
}

#addBtn:hover {
    background-color: #2ee154;
}

#addBtn:pressed {
    background-color: #24943e;
}

#nextBtn {
    background-color: #00989b;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    padding: 12px 24px;
    font-size: 14pt;
    font-weight: 600;
    min-width: 120px;
}

#nextBtn:hover {
    background-color: #00bcc0;
}

#nextBtn:pressed {
    background-color: #01797b;
}

#nextBtn:disabled {
    background-color: #5a6c6e;
    color: #a0b0b2;
}

#backBtn:disabled {
    background-color: #5a6c6e;
    color: #a0b0b2;
}
</string>
  </property>

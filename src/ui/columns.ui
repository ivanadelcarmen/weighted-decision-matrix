  <property name="styleSheet">
   <string notr="true">/* =========================
   Global settings
   ========================= */
#form {
    background-color: #1a1d23;
	font-family: Segoe UI;
}

/* Selection colors */
QLineEdit {
	selection-background-color: #4a9eff;
	selection-color: #ffffff;
}

/* =========================
   Frames
   ========================= */
QFrame {
    border-radius: 8px;
}

#titleFrame {
    background: #00989b;
    padding: 20px;
	margin: 25px 25px 15px 25px;
    border: none;
}

#contentFrame {
    background-color: #f5f7fa;
    padding: 20px;
	margin: 0px 25px 15px 25px;
    border: 1px solid #e1e4e8;
}

#buttonsFrame {
    background-color: transparent;
	margin: 0px 15px 25px 15px;
}

/* =========================
   Title styling
   ========================= */
#titleLabel {
    font-size: 20pt;
    font-weight: 600;
    color: #ffffff;
    letter-spacing: 0.5px;
}

#instructionLabel {
    font-size: 14pt;
    font-weight: 400;
    color: #b8d4f1;
    margin-top: 5px;
}

#weightLabel {
	margin-top: 5
}

/* =========================
   Scroll area
   ========================= */
QScrollArea {
    border: none;
    background-color: transparent;
}

QScrollBar:vertical {
    border: none;
    background: #d1d5da;
    width: 10px;
    border-radius: 5px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background: #959da5;
    border-radius: 5px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background: #6a737d;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
    border: none;
    background: none;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}

/* =========================
   Item cards
   ========================= */
#criteriaWidget {
    background-color: transparent;
}

/* =========================
   Buttons
   ========================= */
#backBtn {
    background-color: #6c757d;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    padding: 14px 28px;
    font-size: 13pt;
    font-weight: 600;
    min-width: 130px;
}

#backBtn:hover {
    background-color: #5a6268;
}

#backBtn:pressed {
    background-color: #545b62;
}

#backBtn:disabled {
    background-color: #6c757d;
    color: #adb5bd;
}

#addBtn {
    background-color: #28a745;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    font-size: 24pt;
    font-weight: bold;
    min-width: 55px;
    min-height: 55px;
    max-width: 55px;
    max-height: 55px;
}

#addBtn:hover {
    background-color: #34ce57;
}

#addBtn:pressed {
    background-color: #1e7e34;
}

#nextBtn {
    background-color: #0366d6;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    padding: 14px 28px;
    font-size: 13pt;
    font-weight: 600;
    min-width: 130px;
}

#nextBtn:hover {
    background-color: #0256c5;
}

#nextBtn:pressed {
    background-color: #024ea4;
}

#nextBtn:disabled {
    background-color: #6c757d;
    color: #adb5bd;
}

#backBtn:disabled {
    background-color: #6c757d;
    color: #adb5bd;
}
</string>
  </property>

  <property name="styleSheet">
   <string notr="true">/* =========================
   Global settings
   ========================= */
#form {
    background-color: #1a1d23;
	font-family: Segoe UI Semibold;
}

/* =========================
   Frames
   ========================= */
QFrame {
    border-radius: 8px;
    border: none;
}

#matrixFrame {
	margin: 20 15 0 15
}

#btnsFrame {
    background-color: transparent;
	margin: 5 15 30 15;
}

/* =========================
   Table settings
   ========================= */
QTableWidget {
    background-color: #ffffff;
    color: #24292e;
	border: none;
	selection-background-color: #d4e8ff;
	selection-color: #24292e;
	gridline-color: #d1d5da;
	font-size: 13pt;
}

QTableWidget::item {
    border: 1px solid #d1d5da;
    padding: 0px;
    margin: 0px;
}

QTableWidget::item:selected {
	background-color: #d4e8ff;
	color: #24292e;
	border: 1px solid #00989b;
}

QTableWidget::item:focus {
	background-color: #d4e8ff;
	color: #24292e;
	padding: 0px;
	margin: 0px;
}

/* Fix for the editor widget that appears on double-click */
QTableWidget QLineEdit {
	border: 2px solid #00989b;
	background-color: #ffffff;
	color: #24292e;
	padding: 2px;
	margin: -1px;
	font-size: 13pt;
	selection-background-color: #4a9eff;
	selection-color: #ffffff;
}

QTableCornerButton::section {
    background-color: #004b4c;
	border: none;
}

QHeaderView::section {
    background-color: #00585a;
    color: #ffffff;
    padding: 8px;
    border: none;
    font-weight: 600;
    font-size: 12pt;
}

/* =========================
   Buttons
   ========================= */
QPushButton {
    background-color: #0366d6;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    padding: 12px 20px;
	margin: 5 10 0 10;
	font-size: 12pt;
    font-weight: 600;
}

QPushButton:hover {
    background-color: #0256c5;
}

QPushButton:pressed {
    background-color: #024ea4;
}

QPushButton:disabled {
    background-color: #6c757d;
    color: #adb5bd;
}

#modifyBtn {
    background-color: #6c757d;
}

#modifyBtn:hover {
    background-color: #5a6268;
}

#modifyBtn:pressed {
    background-color: #545b62;
}

/* =========================
   Scrollbar
   ========================= */
QScrollBar:vertical {
    border: none;
    background: #d1d5da;
    width: 10px;
    border-radius: 5px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background: #959da5;
    border-radius: 5px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background: #6a737d;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
    border: none;
    background: none;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}
</string>
  </property>
